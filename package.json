{
  "name": "facebook-public-group-scraper",
  "version": "0.1.0",
  "description": "Facebook group scraper with Playwright, structured extraction, proxy support, checkpointing, and BI-oriented Gemini XLSX export.",
  "license": "MIT",
  "author": "medramizairi (RidyX)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ridy-saas/Facebook-Public-Group-Scraper-MVP.git"
  },
  "homepage": "https://github.com/ridy-saas/Facebook-Public-Group-Scraper-MVP",
  "bugs": {
    "url": "https://github.com/ridy-saas/Facebook-Public-Group-Scraper-MVP/issues"
  },
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start:no-proxy": "node src/index.js --no-proxy",
